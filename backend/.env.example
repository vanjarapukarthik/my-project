# Server
NODE_ENV=development
PORT=5000
# EC2 + Nginx + PM2: set HOST=127.0.0.1 so only Nginx reaches Node (see deploy/ecosystem.config.cjs). Local dev: omit (defaults to 0.0.0.0).
# HOST=127.0.0.1

# MongoDB Atlas (required for signup/login). Create cluster → Database Access user → Network Access: 0.0.0.0/0 or EC2 IP
# Replace <password> with URL-encoded password if it contains special characters (@ → %40)
MONGODB_URI=mongodb+srv://DB_USER:DB_PASSWORD@cluster0.xxxxx.mongodb.net/telehealth?retryWrites=true&w=majority

# Local MongoDB (alternative): MONGODB_URI=mongodb://localhost:27017/telehealth

# LiveKit (video consultations)
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_SECRET=your_livekit_secret
LIVEKIT_URL=wss://your-livekit-host

# JWT — use a long random string in production (e.g. openssl rand -base64 32)
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

# Browser origin(s) allowed by CORS. Must match how users open the app exactly (scheme + host + port).
# Examples:
#   Vite dev on EC2:     CORS_ORIGIN=http://YOUR_PUBLIC_IP:5173
#   Nginx on port 80:    CORS_ORIGIN=http://YOUR_PUBLIC_IP
# Multiple:              CORS_ORIGIN=http://YOUR_PUBLIC_IP,http://YOUR_PUBLIC_IP:5173
CORS_ORIGIN=http://localhost:5173
