# Server
NODE_ENV=development
PORT=5000

# MongoDB (required for full features)
MONGODB_URI=mongodb://localhost:27017/telehealth
# Or MongoDB Atlas: mongodb+srv://<user>:<password>@cluster.mongodb.net/telehealth?retryWrites=true&w=majority

# LiveKit (video consultations)
LIVEKIT_API_KEY=your_livekit_api_key
LIVEKIT_SECRET=your_livekit_secret
LIVEKIT_URL=wss://your-livekit-host

# Auth (optional, for JWT)
JWT_SECRET=your_jwt_secret_min_32_chars

# CORS (frontend URL)
CORS_ORIGIN=http://localhost:5173
