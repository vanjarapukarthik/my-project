# Telehealth — copy to ".env" in this folder (project root) and fill real values.
# Backend loads this file when you run: npm start / npm run dev from root, or from backend/.

# Server (Express listens here; Vite frontend stays on 5173)
PORT=5000
NODE_ENV=development

# MongoDB Atlas — paste the full connection string from Atlas → Database → Connect → Drivers → Node.js
# Use database name in path: ...mongodb.net/telehealth?retryWrites=true&w=majority
# Password special chars must be URL-encoded (e.g. @ → %40)
MONGODB_URI=mongodb+srv://YOUR_DB_USER:YOUR_DB_PASSWORD@YOUR_CLUSTER_HOST.mongodb.net/telehealth?retryWrites=true&w=majority&appName=Cluster0

# JWT signing secret (use a long random string in production)
JWT_SECRET=replace_with_a_long_random_secret_at_least_32_chars

# Allowed browser origins (comma-separated). Local Vite:
CORS_ORIGIN=http://localhost:5173
