# Copy to backend/.env on EC2 and fill values.
NODE_ENV=production
HOST=127.0.0.1
PORT=5000

MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/DBNAME
JWT_SECRET=change_to_long_random_string

# Same origin as users in the browser (Nginx on port 80 — use your EC2 public URL or domain)
# Example: http://12.34.56.78   or   https://app.yourdomain.com
CORS_ORIGIN=http://YOUR_EC2_PUBLIC_IP_OR_DOMAIN

WS_PATH=/socket.io

LIVEKIT_API_KEY=your_key
LIVEKIT_SECRET=your_secret
LIVEKIT_URL=wss://your-project.livekit.cloud
